{
    "name": "webshr/bricks-builder-stubs",
    "description": "Bricks Builder stubs for static analysis (PHPStan) and IDE autocompletion.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "bricks",
        "bricks-builder",
        "wordpress",
        "static analysis",
        "phpstan",
        "stubs"
    ],
    "homepage": "https://github.com/webshr/bricks-builder-stubs",
    "authors": [
        {
            "name": "Henrik Liebel",
            "email": "hello@webshore.eu",
            "homepage": "https://webshore.eu"
        }
    ],
    "require": {
        "php": "^8.0",
        "php-stubs/wordpress-stubs": "^4.7 || ^5.0 || ^6.0"
    },
    "require-dev": {
        "php-stubs/generator": "^0.8",
        "phpdocumentor/reflection-docblock": "^5.3"
    },
    "suggest": {
        "szepeviktor/phpstan-wordpress": "WordPress extensions for PHPStan"
    },
    "scripts": {
        "generate": "generate-stubs --force --finder=stubs-finder.php --header=\"<?php\" --out=bricks-builder-stubs.php"
    },
    "minimum-stability": "stable"
}
